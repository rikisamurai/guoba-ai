{
  "name": "guoba-docs",
  "type": "module",
  "private": true,
  "scripts": {
    "typedoc": "tsx scripts/build-docs.ts",
    "dev": "pnpm typedoc && pnpm dev:fast",
    "dev:fast": "portless run next dev",
    "build": "pnpm typedoc && next build",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "test": "vitest --run",
    "start": "next start"
  },
  "dependencies": {
    "flexsearch": "^0.8.212",
    "fumadocs-core": "^16.7.16",
    "fumadocs-mdx": "^14.2.14",
    "fumadocs-ui": "^16.8.12",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "portless": "^0.13.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.22.3",
    "typedoc": "^0.28.19",
    "typedoc-plugin-frontmatter": "^1.3.1",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  }
}
