{
  "name": "@guoba-ai/hook",
  "type": "module",
  "version": "0.0.1",
  "description": "A collection of React hooks — zero dependencies, ESM-only, TypeScript-first.",
  "author": "riki",
  "license": "MIT",
  "homepage": "https://guoba-ai.vercel.app/docs",
  "repository": {
    "type": "git",
    "url": "https://github.com/rikisamurai/guoba-ai",
    "directory": "packages/guoba-hook"
  },
  "bugs": {
    "url": "https://github.com/rikisamurai/guoba-ai/issues"
  },
  "keywords": [
    "react",
    "react-hooks",
    "hooks",
    "typescript",
    "esm"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "test": "vitest run",
    "test:type": "tsc --noEmit",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "jsdom": "^29.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.2"
  }
}
