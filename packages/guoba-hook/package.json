{
  "name": "@guoba-ai/hook",
  "version": "0.0.3",
  "description": "A collection of React hooks — zero dependencies, ships dual ESM + CJS, TypeScript-first.",
  "keywords": [
    "esm",
    "hooks",
    "react",
    "react-hooks",
    "typescript"
  ],
  "homepage": "https://guoba-ai.vercel.app/docs",
  "bugs": {
    "url": "https://github.com/rikisamurai/guoba-ai/issues"
  },
  "license": "MIT",
  "author": "riki",
  "repository": {
    "type": "git",
    "url": "https://github.com/rikisamurai/guoba-ai",
    "directory": "packages/guoba-hook"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:type": "tsc --noEmit",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
