{
  "name": "@guoba-ai/utils",
  "type": "module",
  "version": "0.0.2",
  "description": "A collection of TypeScript utility functions — zero dependencies, ESM-only.",
  "author": "riki",
  "license": "MIT",
  "homepage": "https://guoba-ai.vercel.app/docs",
  "repository": {
    "type": "git",
    "url": "https://github.com/rikisamurai/guoba-ai",
    "directory": "packages/guoba-utils"
  },
  "bugs": {
    "url": "https://github.com/rikisamurai/guoba-ai/issues"
  },
  "keywords": [
    "typescript",
    "utils",
    "utilities",
    "esm",
    "tree-shakable",
    "array",
    "object",
    "string",
    "guard"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "release": "pnpm build && pnpm publish",
    "test": "vitest run",
    "test:type": "tsc --noEmit",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsdown": "^0.21.9",
    "typescript": "^6.0.2"
  }
}
