{
  "name": "@guoba-ai/utils",
  "version": "0.0.4",
  "description": "A collection of TypeScript utility functions — zero dependencies, ships dual ESM + CJS.",
  "keywords": [
    "array",
    "esm",
    "guard",
    "object",
    "string",
    "tree-shakable",
    "typescript",
    "utilities",
    "utils"
  ],
  "homepage": "https://guoba-ai.vercel.app/docs",
  "bugs": {
    "url": "https://github.com/rikisamurai/guoba-ai/issues"
  },
  "license": "MIT",
  "author": "riki",
  "repository": {
    "type": "git",
    "url": "https://github.com/rikisamurai/guoba-ai",
    "directory": "packages/guoba-utils"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:type": "tsc --noEmit",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev"
  }
}
