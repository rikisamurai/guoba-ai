{
  "name": "guoba-ai",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "lint": "oxlint --max-warnings 0 --report-unused-disable-directives",
    "lint:fix": "oxlint --fix --max-warnings 0",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "pnpm -r run test",
    "docs:dev": "pnpm --filter guoba-docs dev",
    "docs:build": "pnpm --filter guoba-docs build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r --filter \"./packages/*\" run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "vitest": "^4.1.5"
  }
}
