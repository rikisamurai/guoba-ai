{
  "name": "guoba-ai",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "lint": "oxlint && pnpm -r --parallel run lint && eslint . --max-warnings 0",
    "lint:fix": "oxlint --fix && pnpm -r --parallel run lint:fix && eslint . --fix --max-warnings 0",
    "test": "pnpm -r run test",
    "docs:dev": "pnpm --filter guoba-docs dev",
    "docs:build": "pnpm --filter guoba-docs build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r --filter \"./packages/*\" run build && changeset publish"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@changesets/cli": "^2.31.0",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "eslint": "^10.2.0",
    "eslint-plugin-oxlint": "^1.63.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "jiti": "^2.4.2",
    "oxlint": "^1.63.0",
    "vitest": "^4.1.5"
  }
}
