{
  "name": "guoba-ai",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "lint": "oxlint",
    "lint:ci": "oxlint --format=github",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "pnpm -r run test",
    "dev:docs": "pnpm --filter guoba-docs dev",
    "build:docs": "pnpm --filter guoba-docs build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r --filter \"./packages/*\" run build && changeset publish",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "catalog:dev",
    "simple-git-hooks": "^2.13.1",
    "vitest": "catalog:dev"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "oxfmt --write --no-error-on-unmatched-pattern",
      "oxlint --no-error-on-unmatched-pattern"
    ],
    "*.{json,jsonc,json5,yml,yaml,css,scss,md,mdx,html}": "oxfmt --write --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.5.2"
}
