{
  "name": "guoba-ai",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "lint": "oxlint",
    "lint:ci": "oxlint --format=github",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "pnpm -r run test",
    "docs:dev": "pnpm --filter guoba-docs dev",
    "docs:build": "pnpm --filter guoba-docs build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r --filter \"./packages/*\" run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.5.2"
}
